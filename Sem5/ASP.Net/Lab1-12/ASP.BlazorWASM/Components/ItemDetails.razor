@namespace ASP.BlazorWASM.Components
@using ASP.Domain.Entities

@if (SelectedItem != null)
{
    <div class="card-group col-sm-6 col-md-4">
        <div class="card h-100">
            <div class="card-header">
                <img src="@SelectedItem.Image" class="card-img-top" alt="...">
            </div>
            <div class="card-body">
                <h5 class="card-title">@SelectedItem.Name</h5>
                <p class="card-text">@SelectedItem.Description</p>
                <p class="card-text"><small class="text-body-secondary">@SelectedItem.Price$</small></p>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Movie SelectedItem { get; set; }
}