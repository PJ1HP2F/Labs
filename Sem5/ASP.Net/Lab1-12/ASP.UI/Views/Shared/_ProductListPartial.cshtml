@model ListModel<Movie>

<div id="itemContainer">
    <div class="row mb-3">
        @if (Model.Items != null && Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <div class="card-group col-sm-6 col-md-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <img src="@item.Image" class="card-img-top" alt="...">
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text">@item.Description</p>
                            <p class="card-text"><small class="text-body-secondary">@item.Price$</small></p>
                        </div>
                        <div class="card-footer text-center">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.Id"
                                   asp-route-returnurl="@(ViewContext.HttpContext.Request.Path + ViewContext.HttpContext.Request.QueryString)"
                                   class="btn btn-primary">
                                    Add to cart <i class="bi bi-cart"></i>
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-secondary">
                                    SignIn to add to cart
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p>No items found</p>
        }
    </div>

    <nav aria-label="Page Navigation">
        <pager page-number="@Model.CurrentPage"
             total-pages="@Model.TotalPages"
             category="@(ViewContext.HttpContext.Request.Query["category"])">
        </pager>
    </nav>
</div>