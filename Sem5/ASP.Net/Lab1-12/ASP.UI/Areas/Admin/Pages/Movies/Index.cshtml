@page
@using ASP.UI.Areas.Admin.Pages.Movies
@model ASP.UI.Areas.Admin.Pages.Movies.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].Image)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Movies[0].NormalizedName)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Movies) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
                <td>
                    <img src="@Url.Content(item.Image)" alt="@item.Name" style="max-width:100px; max-height:100px;" />
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">
                        <i class="bi bi-pencil-square"></i> Edit
                    </a>
                    <a asp-page="./Details" asp-route-id="@item.Id">
                        <i class="bi bi-info-circle"></i> Details
                    </a>
                    <a asp-page="./Delete" asp-route-id="@item.Id">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </td>
        </tr>
}
    </tbody>
</table>

<nav aria-label="Page Navigation">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
            <a class="page-link"
               asp-area="Admin"
               asp-page="/Movies/index"
               asp-route-pageNumber="@(Model.CurrentPage - 1)">
                Previous
            </a>
        </li>
        @for (int i = Model.CurrentPage - 2 > 0 ? Model.CurrentPage - 2 : 1;
        i <= (Model.CurrentPage + 2 <= Model.TotalPages ? Model.CurrentPage + 2 : Model.TotalPages); ++i)
        {
            <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                <a class="page-link"
                   asp-area="Admin"
                   asp-page="/Movies/index"
                   asp-route-pageNumber="@i">
                    @i
                </a>
            </li>
        }
        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
            <a class="page-link"
               asp-area="Admin"
               asp-page="/Movies/index"
               asp-route-pageNumber="@(Model.CurrentPage + 1)">
                Next
            </a>
        </li>
    </ul>
</nav>
