@page "/counter/{initialCount:int?}"
@using System.ComponentModel.DataAnnotations
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

<EditForm Model="counterModel" OnValidSubmit="SetCount">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <InputNumber @bind-Value="counterModel.Count" />
        <button type="submit" class="btn btn-primary">Set</button>
    </div>
</EditForm>

@code {
    public class CounterModel()
    {
        [Range(1, 10, ErrorMessage = "Count should be [1;10]")]
        public int Count { get; set; }
    }

    private CounterModel counterModel = new();

    [Parameter]
    public int? InitialCount { get; set; }

    private int currentCount = 0;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (InitialCount.HasValue)
        {
            currentCount = InitialCount.Value;
        }
    }

    private void IncrementCount()
    {
        ++currentCount;
    }

    private void SetCount()
    {
        currentCount = counterModel.Count;
    }
}
