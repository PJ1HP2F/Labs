@startuml

skinparam shadowing false
skinparam defaultTextAlignment center

[*] --> Ожидание_соперника : Создание игры (хост)

Ожидание_соперника --> Расстановка : Соперник присоединился

Расстановка --> Бой : Оба игрока расставили корабли

state Бой {
  [*] --> Ход_игрока1
  Ход_игрока1 --> Ход_игрока2 : Промах
  Ход_игрока2 --> Ход_игрока1 : Промах
  Ход_игрока1 --> Ход_игрока1 : Попадание / уничтожение
  Ход_игрока2 --> Ход_игрока2 : Попадание / уничтожение
}

Бой --> Игра_завершена : Все корабли уничтожены

Игра_завершена --> [*]

@enduml